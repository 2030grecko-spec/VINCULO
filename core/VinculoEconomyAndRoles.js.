export const VinculoSystem = {
    // LA BÓVEDA (VÍNCULO BANK)
    wallet: {
        currency: "V-Coins",
        balance: 0,
        logic: {
            conversionRate: 1.0,
            addFunds(amount) {
                this.balance += amount;
            },
            spendFunds(cost) {
                if (this.balance >= cost) {
                    this.balance -= cost;
                    return true;
                }
                return false;
            }
        }
    },

    // CAMILA MULTI-ROL
    camilaRoles: {
        currentMode: "Standard",
        modes: {
            "Standard": { skin: "Camila_Normal", knowledge: "General" },
            "Intelectual": { skin: "Camila_Con_Lentes", knowledge: "Python_Tutor" },
            "Business": { skin: "Camila_Bata_Profesor", knowledge: "Engine_Master" }
        },
        setRole(newMode) {
            this.currentMode = newMode;
            return this.modes[newMode];
        }
    }
};

